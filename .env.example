# Copy this file to .env and fill in your key to enable receipt scanning.
# Without it, the app still works fully — the Scan step just falls back to manual entry.
ANTHROPIC_API_KEY=

# Optional — port for the local OCR server (server/index.ts)
PORT=8787

# Supabase — client-safe values only. Get these from your Supabase project's
# Settings > API page. Never put the service_role/secret key here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
